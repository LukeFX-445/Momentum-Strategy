# ─────────────────────────────────────────────────────────────────────────────
# INDICATOR CALCULATIONS
# ─────────────────────────────────────────────────────────────────────────────

def _wilder(series: pd.Series, period: int) -> pd.Series:
    """
    Wilder's smoothed moving average (RMA).
    Equivalent to Pine Script's ta.rma() — used for ATR and ADX.
    """
    return series.ewm(alpha=1.0 / period, adjust=False).mean()


def calc_atr(high: pd.Series, low: pd.Series, close: pd.Series,
             period: int = 14) -> pd.Series:
    """14-period ATR using Wilder smoothing."""
    tr = pd.concat([
        high - low,
        (high - close.shift(1)).abs(),
        (low  - close.shift(1)).abs(),
    ], axis=1).max(axis=1)
    return _wilder(tr, period)


def calc_adx(high: pd.Series, low: pd.Series, close: pd.Series,
             period: int = 14) -> pd.Series:
    """
    ADX using Wilder smoothing.
    Returns the ADX line only (directional strength, not direction).
    """
    tr = pd.concat([
        high - low,
        (high - close.shift(1)).abs(),
        (low  - close.shift(1)).abs(),
    ], axis=1).max(axis=1)

    up   = high.diff()
    dn   = -low.diff()

    plus_dm  = pd.Series(np.where((up > dn)  & (up > 0),  up, 0.0), index=high.index)
    minus_dm = pd.Series(np.where((dn > up)  & (dn > 0),  dn, 0.0), index=high.index)

    atr_s    = _wilder(tr, period)
    plus_di  = 100 * _wilder(plus_dm,  period) / atr_s
    minus_di = 100 * _wilder(minus_dm, period) / atr_s

    denom = (plus_di + minus_di).replace(0, np.nan)
    dx    = 100 * (plus_di - minus_di).abs() / denom
    adx   = _wilder(dx.fillna(0), period)
    return adx


def calc_adr(high: pd.Series, low: pd.Series, period: int = 5) -> pd.Series:
    """
    5-day Average Daily Range, forward-filled onto 4H bar index.
    Computed by resampling 4H highs/lows to daily, then rolling mean.
    """
    daily_hi  = high.resample('1D').max()
    daily_lo  = low.resample('1D').min()
    daily_rng = (daily_hi - daily_lo).rolling(period).mean()
    # Forward-fill daily value onto every 4H bar in that day
    return daily_rng.reindex(high.index, method='ffill')


# ─────────────────────────────────────────────────────────────────────────────
# OANDA 4H CANDLE BUILDER
# ─────────────────────────────────────────────────────────────────────────────

def build_4h_candles(
    df_1h: pd.DataFrame,
    london_tz: str = 'Europe/London',
    valid_hours: frozenset = frozenset({2, 6, 10, 14, 18}),
    drop_empty_bars: bool = True,
    use_session_filter: bool = True,
    resample_offset: str = '0h',
) -> pd.DataFrame:
    """
    Resample 1H OHLCV data into OANDA-style 4H candles.

    Parameters
    ----------
    df_1h              : DataFrame with columns [open, high, low, close] (+ optional volume).
                         Index must be a UTC-aware DatetimeIndex.
    london_tz          : Timezone string for conversion (default 'Europe/London').
    valid_hours        : Set of London-time hours that define valid session opens.
    drop_empty_bars    : If True (default), drop candles where high == low or
                         volume == 0 (when volume is present). Removes hollow
                         overnight/weekend bars produced for market-hours instruments.
    use_session_filter : If True (default), apply OANDA London session logic —
                         resample anchored at 02:00 London and keep only candles
                         at valid_hours (drops the 22:00 overnight candle).
                         Set False for CFD/Yahoo data that trades 24/5 continuously;
                         bars are then anchored at midnight UTC with no hour filter.
    resample_offset    : UTC offset for 4H bar anchor when use_session_filter=False.
                         '0h'  → Anchor A: bars at 00:00, 04:00, 08:00, 12:00, 16:00, 20:00
                         '2h'  → Anchor B: bars at 02:00, 06:00, 10:00, 14:00, 18:00, 22:00
                         Ignored when use_session_filter=True (London offset applies).

    Returns
    -------
    DataFrame of 4H candles.
    """
    df = df_1h.copy()
    if df.index.tz is None:
        df.index = df.index.tz_localize('UTC')

    agg_rules = {'open': 'first', 'high': 'max', 'low': 'min', 'close': 'last'}

    if use_session_filter:
        # Convert to London time so session hours align correctly
        df_target = df.copy()
        df_target.index = df_target.index.tz_convert(london_tz)
        if 'volume' in df_target.columns:
            agg_rules['volume'] = 'sum'
        candles = (
            df_target
            .resample('4h', offset='2h')
            .agg(agg_rules)
            .dropna(subset=['open'])
        )
        # Keep only candles opening at valid London hours (drops the 22:00 candle)
        candles = candles[candles.index.hour.isin(valid_hours)]
    else:
        # Standard 4H bars anchored at midnight UTC, no hour filtering.
        # resample_offset shifts the anchor: '0h' = midnight, '2h' = 02:00 UTC.
        if 'volume' in df.columns:
            agg_rules['volume'] = 'sum'
        candles = (
            df
            .resample('4h', offset=resample_offset)
            .agg(agg_rules)
            .dropna(subset=['open'])
        )

    # Drop empty bars: flat candles and zero-volume bars from market-hours gaps.
    # Volume filter is skipped when all values are zero (price indices like ^FTSE
    # carry no meaningful volume from Yahoo Finance).
    if drop_empty_bars:
        candles = candles[candles['high'] != candles['low']]
        if 'volume' in candles.columns and (candles['volume'] > 0).any():
            candles = candles[candles['volume'] > 0]

    return candles


# ─────────────────────────────────────────────────────────────────────────────
# SIGNAL GENERATION
# ─────────────────────────────────────────────────────────────────────────────

def generate_signals(df: pd.DataFrame, params: Optional[dict] = None) -> pd.DataFrame:
    """
    Apply all Omor 4H sweep conditions to a candle DataFrame.
    
    Returns the original DataFrame with the following columns appended:

    Indicators:
      ma50, ma200       — simple moving averages
      atr14             — 14-period ATR (Wilder)
      adx14             — 14-period ADX
      adr5              — 5-day Average Daily Range (forward-filled)

    Condition flags (all boolean):
      c_sweep_low       — low[i] < low[i-1]
      c_sweep_high      — high[i] > high[i-1]
      c_close70_bull    — close >= ((H-L)*0.70)+L
      c_close70_bear    — close <= H - ((H-L)*0.70)
      c_above_ma200     — close > MA200 × 0.995  (soft bias: 0.5% below still passes)
      c_below_ma200     — close < MA200 × 1.005  (soft bias: 0.5% above still passes)
      c_ma50_tap_long   — close > MA50
      c_ma50_tap_short  — close < MA50
      c_ma50_dist_long  — abs(low - MA50) <= ATR14   (diagnostic only, not used in signal)
      c_ma50_dist_short — abs(high - MA50) <= ATR14  (diagnostic only, not used in signal)
      c_adx_ok          — ADX > threshold
      c_adr_ok          — 4H range <= 0.75 × ADR5    (diagnostic only, not used in signal)

    Signals:
      long_signal       — all long conditions met
      short_signal      — all short conditions met
    """
    p = {**PARAMS, **(params or {})}
    d = df.copy()

    # ── Indicators ────────────────────────────────────────────────────────────
    d['ma50']  = d['close'].rolling(p['ma_fast']).mean()
    d['ma200'] = d['close'].rolling(p['ma_slow']).mean()
    d['atr14'] = calc_atr(d['high'], d['low'], d['close'], p['atr_period'])
    d['adx14'] = calc_adx(d['high'], d['low'], d['close'], p['adx_period'])
    d['adr5']  = calc_adr(d['high'], d['low'], p['adr_period'])

    candle_range = d['high'] - d['low']
    d['avg_range_5'] = candle_range.rolling(5).mean()

    # ── 1. Sweep ──────────────────────────────────────────────────────────────
    d['c_sweep_low']  = d['low']  < d['low'].shift(1)
    d['c_sweep_high'] = d['high'] > d['high'].shift(1)

    # ── 2. 70% close rule ─────────────────────────────────────────────────────
    # Long:  close must be in the upper 30% of the candle
    # Short: close must be in the lower 30% of the candle
    d['c_close70_bull'] = d['close'] >= (candle_range * p['close_pct']) + d['low']
    d['c_close70_bear'] = d['close'] <= d['high'] - (candle_range * p['close_pct'])

    # ── 3. MA200 soft bias ────────────────────────────────────────────────────
    # Allow signals within 0.5% of MA200 rather than hard-rejecting at the line.
    d['c_above_ma200'] = d['close'] > d['ma200'] * 0.995
    d['c_below_ma200'] = d['close'] < d['ma200'] * 1.005

    # ── 4. MA50 tap ───────────────────────────────────────────────────────────
    # Close must have recovered to the correct side of MA50.
    d['c_ma50_tap_long']   = d['close'] > d['ma50']
    d['c_ma50_tap_short']  = d['close'] < d['ma50']

    # ── MA50 distance (diagnostic only — not used in signal) ─────────────────
    d['c_ma50_dist_long']  = (d['ma50'] - d['low']).abs()  <= d['atr14']
    d['c_ma50_dist_short'] = (d['high'] - d['ma50']).abs() <= d['atr14']

    # ── 5. ADX trend filter ───────────────────────────────────────────────────
    d['c_adx_ok'] = d['adx14'] > p['adx_threshold']

    # ── ADR overextension (diagnostic only — not used in signal) ─────────────
    # Kept for inspection; removed as a filter because it specifically rejects
    # large sweep candles that are the core of this setup.
    d['c_adr_ok'] = candle_range <= (d['adr5'] * p['adr_cap_pct'])

    # ── Candle size filters ───────────────────────────────────────────────────
    # max: rejects oversized sweep candles where the SL distance is too wide.
    # min: rejects undersized sweep candles that lack momentum.
    max_csf = p.get('max_candle_filter', None)
    min_csf = p.get('min_candle_filter', None)

    c_candle_max_ok = (
        candle_range <= max_csf * d['avg_range_5']
        if max_csf is not None
        else pd.Series(True, index=d.index)
    )
    c_candle_min_ok = (
        candle_range >= min_csf * d['avg_range_5']
        if min_csf is not None
        else pd.Series(True, index=d.index)
    )

    # ── Combined signals ──────────────────────────────────────────────────────
    d['long_signal'] = (
        d['c_sweep_low']     &
        d['c_close70_bull']  &
        d['c_above_ma200']   &
        d['c_ma50_tap_long'] &
        d['c_adx_ok']        &
        c_candle_max_ok      &
        c_candle_min_ok
    )

    d['short_signal'] = (
        d['c_sweep_high']      &
        d['c_close70_bear']    &
        d['c_below_ma200']     &
        d['c_ma50_tap_short']  &
        d['c_adx_ok']          &
        c_candle_max_ok        &
        c_candle_min_ok
    )

    return d


# ─────────────────────────────────────────────────────────────────────────────
# BACKTESTER
# ─────────────────────────────────────────────────────────────────────────────

def backtest(
    df: pd.DataFrame,
    params: Optional[dict] = None,
    verbose: bool = False
):
    """
    Bar-by-bar backtest of the Omor 4H sweep system.

    Trade logic:
      - Signal fires on bar i
      - Entry at open of bar i+1
      - SL at low[i] (long) or high[i] (short)
      - TP at entry ± risk * RR
      - One trade at a time; no pyramiding

    Parameters
    ----------
    df      : DataFrame of 4H candles (output of build_4h_candles).
    params  : Override any PARAMS values.
    verbose : Print each trade entry to console.

    Returns
    -------
    trades_df : DataFrame with one row per trade.
    summary   : Dict of performance metrics.
    """
    p = {**PARAMS, **(params or {})}
    rr = p['rr']

    d = generate_signals(df, p)

    trades     = []
    in_trade   = False
    direction  = None
    entry = sl = tp = None

    for i in range(1, len(d)):
        row  = d.iloc[i]
        prev = d.iloc[i - 1]

        # ── Manage open trade ─────────────────────────────────────────────────
        if in_trade:
            hi, lo = row['high'], row['low']

            if direction == 'LONG':
                if lo <= sl:
                    trades[-1].update(exit_price=sl, result='LOSS',
                                      pnl_r=-1.0, exit_time=row.name)
                    in_trade = False
                elif hi >= tp:
                    trades[-1].update(exit_price=tp, result='WIN',
                                      pnl_r=rr, exit_time=row.name)
                    in_trade = False

            else:  # SHORT
                if hi >= sl:
                    trades[-1].update(exit_price=sl, result='LOSS',
                                      pnl_r=-1.0, exit_time=row.name)
                    in_trade = False
                elif lo <= tp:
                    trades[-1].update(exit_price=tp, result='WIN',
                                      pnl_r=rr, exit_time=row.name)
                    in_trade = False
            continue  # don't look for new entries while in a trade

        # ── New LONG entry ────────────────────────────────────────────────────
        if prev['long_signal']:
            entry = row['open']
            sl    = prev['low'] - p.get('sl_buffer', 0.0) * prev['atr14']
            if entry <= sl:    # adverse gap — signal invalidated
                continue
            tp        = entry + (entry - sl) * rr
            direction = 'LONG'
            in_trade  = True
            trades.append({
                'entry_time': row.name,   'direction': 'LONG',
                'entry':      entry,      'sl':        sl,
                'tp':         tp,         'exit_price': None,
                'result':     None,       'pnl_r':     None,
                'exit_time':  None,
            })
            if verbose:
                print(f"[LONG]  {row.name}  entry={entry:.5f}  sl={sl:.5f}  tp={tp:.5f}")

        # ── New SHORT entry ───────────────────────────────────────────────────
        elif prev['short_signal']:
            entry = row['open']
            sl    = prev['high'] + p.get('sl_buffer', 0.0) * prev['atr14']
            if entry >= sl:    # adverse gap — signal invalidated
                continue
            tp        = entry - (sl - entry) * rr
            direction = 'SHORT'
            in_trade  = True
            trades.append({
                'entry_time': row.name,   'direction': 'SHORT',
                'entry':      entry,      'sl':        sl,
                'tp':         tp,         'exit_price': None,
                'result':     None,       'pnl_r':     None,
                'exit_time':  None,
            })
            if verbose:
                print(f"[SHORT] {row.name}  entry={entry:.5f}  sl={sl:.5f}  tp={tp:.5f}")

    # ── Results ───────────────────────────────────────────────────────────────
    trades_df = pd.DataFrame(trades)

    if trades_df.empty:
        print("No trades generated.")
        return trades_df, {}

    closed   = trades_df.dropna(subset=['result'])
    wins     = int((closed['result'] == 'WIN').sum())
    losses   = int((closed['result'] == 'LOSS').sum())
    total    = len(closed)
    wr       = wins / total if total else 0.0
    total_r  = round(closed['pnl_r'].sum(), 2)
    avg_r    = round(closed['pnl_r'].mean(), 3)
    # Expectancy per trade: (WR × avg_win) + (LR × avg_loss)
    # With fixed RR: E = WR*RR - (1-WR)*1
    expectancy = round(wr * rr - (1 - wr), 3)

    # Breakdown by direction
    long_closed  = closed[closed['direction'] == 'LONG']
    short_closed = closed[closed['direction'] == 'SHORT']

    summary = {
        'total_signals':        len(trades_df),
        'closed_trades':        total,
        'open_at_end':          len(trades_df) - total,
        'wins':                 wins,
        'losses':               losses,
        'win_rate_pct':         round(wr * 100, 2),
        'total_r':              total_r,
        'avg_r_per_trade':      avg_r,
        'expectancy_per_trade': expectancy,
        'rr':                   rr,
        'long_trades':          len(long_closed),
        'long_win_rate_pct':    round((long_closed['result'] == 'WIN').mean() * 100, 2)
                                if len(long_closed) else 0.0,
        'short_trades':         len(short_closed),
        'short_win_rate_pct':   round((short_closed['result'] == 'WIN').mean() * 100, 2)
                                if len(short_closed) else 0.0,
    }

    return trades_df, summary


# ─────────────────────────────────────────────────────────────────────────────
# SIGNAL INSPECTOR  (for manual review of individual signals)
# ─────────────────────────────────────────────────────────────────────────────

def inspect_signals(df: pd.DataFrame, params: Optional[dict] = None,
                    n: int = 10) -> pd.DataFrame:
    """
    Return the last n long or short signals with all condition flags visible.
    Useful for manually validating the logic before committing to a backtest.
    """
    d = generate_signals(df, params)
    condition_cols = [c for c in d.columns if c.startswith('c_') or c in
                      ('ma50', 'ma200', 'atr14', 'adx14', 'adr5',
                       'long_signal', 'short_signal')]

    signals = d[(d['long_signal'] | d['short_signal'])]
    return signals[['open', 'high', 'low', 'close'] + condition_cols].tail(n)


